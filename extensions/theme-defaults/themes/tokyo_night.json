	"tokenColors": [
		{
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": {
				"foreground": "#565f89"
			}
		},
		{
			"scope": [
				"constant",
				"constant.language",
				"variable.language",
				"support.constant"
			],
			"settings": {
				"foreground": "#bb9af7"
			}
		},
		{
			"scope": [
				"constant.numeric",
				"constant.other.color"
			],
			"settings": {
				"foreground": "#ff9e64"
			}
		},
		{
			"scope": [
				"entity.name.function",
				"support.function",
				"support.constant.handlebars"
			],
			"settings": {
				"foreground": "#7aa2f7"
			}
		},
		{
			"scope": [
				"entity.name.type",
				"entity.name.class",
				"entity.name.namespace",
				"entity.name.scope-resolution",
				"support.class",
				"support.type",
				"meta.type.cast.expr",
				"meta.type.new.expr",
				"entity.other.inherited-class"
			],
			"settings": {
				"foreground": "#ff9e64"
			}
		},
		{
			"scope": [
				"entity.name.tag"
			],
			"settings": {
				"foreground": "#f7768e"
			}
		},
		{
			"scope": [
				"entity.other.attribute-name"
			],
			"settings": {
				"foreground": "#73daca"
			}
		},
		{
			"scope": [
				"keyword",
				"keyword.control",
				"keyword.operator.new",
				"keyword.operator.delete",
				"keyword.other.using",
				"keyword.other.directive.using",
				"keyword.other.operator",
				"entity.name.operator"
			],
			"settings": {
				"foreground": "#bb9af7"
			}
		},
		{
			"scope": [
				"keyword.operator",
				"keyword.operator.expression",
				"keyword.operator.arithmetic",
				"keyword.operator.assignment",
				"keyword.operator.comparison",
				"keyword.operator.logical"
			],
			"settings": {
				"foreground": "#89ddff"
			}
		},
		{
			"scope": [
				"string",
				"string.quoted",
				"string.template",
				"string.interpolated",
				"string.regexp",
				"punctuation.definition.string"
			],
			"settings": {
				"foreground": "#9ece6a"
			}
		},
		{
			"scope": [
				"variable",
				"variable.other.readwrite",
				"meta.definition.variable.name",
				"support.variable",
				"entity.name.variable",
				"meta.object-literal.key"
			],
			"settings": {
				"foreground": "#a9b1d6"
			}
		},
		{
			"scope": [
				"variable.other.constant",
				"variable.other.enummember"
			],
			"settings": {
				"foreground": "#bb9af7"
			}
		},
		{
			"scope": [
				"variable.other.property",
				"support.variable.property"
			],
			"settings": {
				"foreground": "#7dcfff"
			}
		},
		{
			"scope": [
				"storage",
				"storage.type",
				"storage.modifier"
			],
			"settings": {
				"foreground": "#bb9af7"
			}
		},
		{
			"scope": [
				"support",
				"support.type.property-name",
				"support.constant.proeprty-value",
				"support.constant.font-name",
				"support.constant.media",
				"support.constant.color"
			],
			"settings": {
				"foreground": "#7dcfff"
			}
		},
		{
			"scope": [
				"punctuation",
				"punctuation.separator",
				"punctuation.definition"
			],
			"settings": {
				"foreground": "#565f89"
			}
		},
		{
			"scope": [
				"punctuation.definition.tag",
				"meta.tag"
			],
			"settings": {
				"foreground": "#f7768e"
			}
		},
		{
			"scope": [
				"invalid",
				"invalid.illegal"
			],
			"settings": {
				"foreground": "#f7768e"
			}
		},
		{
			"scope": [
				"markup.heading",
				"entity.name.section"
			],
			"settings": {
				"foreground": "#7aa2f7",
				"fontStyle": "bold"
			}
		},
		{
			"scope": [
				"markup.italic"
			],
			"settings": {
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"markup.bold"
			],
			"settings": {
				"fontStyle": "bold"
			}
		},
		{
			"scope": [
				"markup.underline.link",
				"markup.underline.link.image"
			],
			"settings": {
				"foreground": "#7aa2f7",
				"fontStyle": "underline"
			}
		},
		{
			"scope": [
				"markup.changed"
			],
			"settings": {
				"foreground": "#e0af68"
			}
		},
		{
			"scope": [
				"markup.deleted"
			],
			"settings": {
				"foreground": "#f7768e"
			}
		},
		{
			"scope": [
				"markup.inserted"
			],
			"settings": {
				"foreground": "#9ece6a"
			}
		},
		{
			"scope": [
				"markup.raw"
			],
			"settings": {
				"foreground": "#9ece6a"
			}
		},
		{
			"scope": [
				"meta.diff.header",
				"meta.diff.range",
				"meta.separator"
			],
			"settings": {
				"foreground": "#bb9af7"
			}
